# Copy this file to supabase/.env.test and fill in values from your hosted
# Supabase project (Settings → API). supabase/.env.test is gitignored.
#
# - SUPABASE_URL: Project URL (e.g. https://abcdwxyz.supabase.co)
# - SUPABASE_ANON_KEY: "anon" public key — safe to ship to clients
# - SUPABASE_SERVICE_ROLE_KEY: "service_role" secret key — bypasses RLS,
#   never commit and never ship to clients. Lives in your password manager
#   and (later) the CalDAV proxy's Vercel env vars.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
